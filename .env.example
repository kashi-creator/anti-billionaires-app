# --- Core ---
# 'production' or 'development'. Production fails if SECRET_KEY is missing.
FLASK_ENV=development
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-64-char-hex-from-secrets.token_hex

# --- Database ---
# Local: leave unset to use sqlite:///abmc.db
# Prod (Railway): set automatically when Postgres plugin is attached
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Stripe (Phase 4) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID=price_xxx

# --- Resend (Phase 3) ---
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@onepercentmensclub.com
EMAIL_FROM_NAME=The 1% Men's Club

# --- Anthropic / AI Wingman (Phase 7) ---
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-6
WINGMAN_DAILY_MESSAGE_CAP=50

# --- Admin (Phase 9) ---
# Comma-separated emails granted /admin access
ADMIN_EMAILS=kashi@thebreathcoachschool.com

# --- GoHighLevel (existing, optional) ---
GHL_API_KEY=
GHL_LOCATION_ID=

# --- Founder bypass codes (legacy; will be replaced by Stripe coupons in Phase 4) ---
# FOUNDER_CODES=ABMC2026,VIP2026
